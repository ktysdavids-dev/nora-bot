# ===== Nora · variables de entorno =====
# Copia a .env y rellena.

BUSINESS_ID=casa-nerea
PORT=8080
# URL pública de tu despliegue (Render). La usan las funciones de voz.
PUBLIC_URL=https://nora-xxxx.onrender.com

# ===== MOTOR DE VOZ RECOMENDADO: Retell + voz ElevenLabs + LLM a elegir =====
# Retell orquesta la llamada (telefonía, turnos, interrupciones) y llama a
# nuestras funciones en /tools/*. La voz la pone ElevenLabs (la más natural).
# El LLM lo eliges TÚ dentro de Retell: Claude, Gemini o GPT. No dependes de OpenAI.
RETELL_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ===== Telefonía =====
# Usa el número que da Retell, o conecta tu Twilio a Retell.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+34...

# ===== Glop (TPV) =====

# ===== Demo de venta (texto) =====
OPENAI_API_KEY=
DEMO_MODEL=gpt-4o-mini

# ===== Alternativa: voz 100% OpenAI Realtime (solo si quieres ese camino) =====
REALTIME_MODEL=gpt-realtime
NORA_VOICE=shimmer

# --- Glop (TPV) · credenciales SOLO en el servidor ---
GLOP_ENABLED=false
GLOP_API_BASE=
GLOP_CLIENT_ID=
GLOP_SECRET=
GLOP_USER_ID=

# --- Soporte remoto (panel Nora Control) ---
ADMIN_TOKEN=
BOT_VERSION=1.0.0
CLIENT_TOKEN=
